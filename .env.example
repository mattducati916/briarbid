# ============================================================
# BriarBid — Environment Variables
# Copy this file to .env for local dev (never commit .env)
# Set these same variables in Netlify → Site Settings → Env Vars
# ============================================================

# PostgreSQL connection string (from Neon, Supabase, etc.)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/briarbid?sslmode=require

# JWT secret — generate a random 64-char string
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret-string
